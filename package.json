{
  "name": "tiny-string-tools",
  "version": "1.1.4",
  "description": "A lightweight, zero-dependency, highly optimized utility library for common string manipulations like slugify, truncate, capitalize, and text masking.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prabhat081/tiny-string-tools.git"
  },
  "keywords": [
    "string",
    "string-manipulation",
    "slugify",
    "truncate",
    "capitalize",
    "get-initials",
    "mask-text",
    "clean-spaces",
    "validation",
    "utility",
    "utils",
    "typescript"
  ],
  "author": "Prabhat Kumar",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
